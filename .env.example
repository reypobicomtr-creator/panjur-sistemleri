# ════════════════════════════════════════════════
# 1. Supabase.com'da yeni bir proje oluşturun
# 2. Sol menü > Project Settings > API bölümüne gidin
# 3. "Project URL" ve "anon public" değerlerini aşağıya yazın
# 4. Bu dosyayı .env olarak kaydedin (örn: .env.local)
# 5. supabase-schema.sql'i Supabase SQL Editor'da çalıştırın
# 6. Supabase Authentication > Users sayfasından admin kullanıcısı oluşturun
# ════════════════════════════════════════════════

VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
